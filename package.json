{
  "name": "assurmoi",
  "version": "1.0.0",
  "description": "App Assurmoi API",
  "license": "ISC",
  "author": "Mamadou Barry <mabarry2018@gmail.com>",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node src/app.ts",
    "build": "tsc && node -e \"require('fs').copyFileSync('dist/src/config/database.js','dist/src/config/database.cjs')\"",
    "sequelize": "node -r ts-node/register ./node_modules/sequelize-cli/lib/sequelize",
    "db:migrate": "npm run build && npm run sequelize -- db:migrate",
    "db:migrate:undo": "npm run build && npm run sequelize -- db:migrate:undo",
    "db:migrate:status": "npm run build && npm run sequelize -- db:migrate:status",
    "start": "node dist/app.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "mariadb": "^3.5.2",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "homepage": "https://github.com/adamsbarry18/app-assurmoi-API.node#readme",
  "bugs": {
    "url": "https://github.com/adamsbarry18/app-assurmoi-API.node/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamsbarry18/app-assurmoi-API.node.git"
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}