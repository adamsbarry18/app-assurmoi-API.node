PORT=3000
NODE_ENV=development
# URL publique de l’API pour les logs HTTP (sinon dérivée de Host + protocol)
# API_URL=http://localhost:3000
# HOST=localhost
# Nom affiché dans les logs HTTP (défaut : name du package.json)
# APP_NAME=assurmoi-api
# error | warn | info | debug
LOG_LEVEL=info

# JWT — access token (Bearer) + refresh ; min. 16 caractères pour JWT_SECRET
JWT_SECRET=change_me_min_16_chars_secret
# JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_RESET_EXPIRES=1h
JWT_INVITE_EXPIRES=7d
# JWT_RESET_SECRET= (optionnel, défaut JWT_SECRET)

# Liens dans les emails (reset, invitation)
PUBLIC_APP_URL=http://localhost:3000

# database configuration
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_HOST=your_database_host
DB_PORT=3306
DB_NAME=your_database_name

# email — MAIL_BACKEND=console : affichage terminal (pas d’envoi). Sinon SMTP.
MAIL_BACKEND=console
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM=noreply@assurmoi.local
# TLS auto-signé / dev : SMTP_REJECT_UNAUTHORIZED=false