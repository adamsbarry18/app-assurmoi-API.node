PORT=3000
NODE_ENV=development

# database configuration
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_HOST=your_database_host
DB_PORT=3306
DB_NAME=your_database_name

# email (nodemailer) — MAIL_FROM obligatoire si SMTP_USER vide
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM=noreply@assurmoi.local
# TLS auto-signé / dev : SMTP_REJECT_UNAUTHORIZED=false