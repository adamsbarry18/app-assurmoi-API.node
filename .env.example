PORT=3000
NODE_ENV=development
# Production : origines CORS autorisées (séparateur virgule), ex. https://app.mondomaine.fr
# En dev, l’API accepte toute origine (Expo : localhost:8081, 192.168.x, etc.)
# CORS_ALLOWED_ORIGINS=https://app.mondomaine.fr,https://www.mondomaine.fr
# URL publique de l’API pour les logs HTTP (sinon dérivée de Host + protocol)
# API_URL=http://localhost:3000
# HOST=localhost
# Nom affiché dans les logs HTTP (défaut : name du package.json)
# APP_NAME=assurmoi-api
# error | warn | info | debug
LOG_LEVEL=info

# JWT — access token (Bearer) + refresh ; min. 16 caractères pour JWT_SECRET
JWT_SECRET=change_me_min_16_chars_secret
# JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_RESET_EXPIRES=1h
JWT_INVITE_EXPIRES=7d
# JWT_RESET_SECRET= (optionnel, défaut JWT_SECRET)

# Liens dans les emails (reset, invitation)
PUBLIC_APP_URL=http://localhost:3000

# database configuration
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_HOST=your_database_host
DB_PORT=3306
DB_NAME=your_database_name

# Stockage des fichiers uploadés (défaut : ./uploads dans le projet)
# UPLOAD_DIR=/var/lib/assurmoi/uploads
# Taille max upload (octets), défaut 15 Mo
# UPLOAD_MAX_BYTES=15728640

# email — MAIL_BACKEND=console : affichage terminal (pas d’envoi). Sinon SMTP.
MAIL_BACKEND=console
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM=noreply@assurmoi.local

# Yousign (API v3) — signature électronique
YOUSIGN_API_KEY=
# Production : https://api.yousign.app/v3 — Sandbox : https://api-sandbox.yousign.app/v3
# YOUSIGN_BASE_URL=https://api-sandbox.yousign.app/v3